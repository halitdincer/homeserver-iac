{
  "uid": "homeserver-logs",
  "title": "Homeserver Logs",
  "tags": ["homeserver", "logs"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "annotations": {"list": []},
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": {"type": "loki", "uid": "loki"},
        "query": {"label": "namespace", "refId": "LokiVariableQueryEditor-VariableQuery", "stream": "", "type": 1},
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]},
        "label": "Namespace"
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": {"type": "loki", "uid": "loki"},
        "query": {"label": "pod", "refId": "LokiVariableQueryEditor-VariableQuery", "stream": "{namespace=~\"$namespace\"}", "type": 1},
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]},
        "label": "Pod"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Log Rate (lines/s)",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "sum(rate({namespace=~\"$namespace\"}[5m]))", "refId": "A", "queryType": "instant"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1, "color": {"mode": "fixed", "fixedColor": "blue"}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error/Warn Rate (lines/s)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "sum(rate({namespace=~\"$namespace\"} |~ \"(?i)error|fatal|panic|warn\"[5m]))", "refId": "A", "queryType": "instant"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Namespaces",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "count(count by (namespace) (rate({namespace=~\".+\"}[5m]) > 0))", "refId": "A", "queryType": "instant"}],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "purple"}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Pods",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "count(count by (pod) (rate({namespace=~\"$namespace\"}[5m]) > 0))", "refId": "A", "queryType": "instant"}],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "purple"}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Log Volume by Namespace",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "sum by (namespace) (rate({namespace=~\"$namespace\"}[1m]))", "refId": "A", "legendFormat": "{{namespace}}"}],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 25, "stacking": {"mode": "normal"}}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error/Warn Rate by Namespace",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "sum by (namespace) (rate({namespace=~\"$namespace\"} |~ \"(?i)error|fatal|panic|warn\"[1m]))", "refId": "A", "legendFormat": "{{namespace}}"}],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10}}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Top 10 Noisiest Pods",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "topk(10, sum by (namespace, pod) (rate({namespace=~\"$namespace\"}[5m])))", "refId": "A", "queryType": "instant", "legendFormat": "{{namespace}}/{{pod}}"}],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "continuous-BlYlRd"}}, "overrides": []},
      "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "valueMode": "color", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Live Tail",
      "gridPos": {"h": 14, "w": 24, "x": 0, "y": 20},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "{namespace=~\"$namespace\", pod=~\"$pod\"}", "refId": "A"}],
      "options": {"showLabels": false, "showTime": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending"}
    }
  ]
}
