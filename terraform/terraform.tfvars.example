# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git!

# Proxmox API credentials
proxmox_api_url  = "https://10.10.10.1:8006/api2/json"
proxmox_user     = "root@pam"
proxmox_password = "your-proxmox-root-password"

# Proxmox node
proxmox_node = "pve1"

# Network settings
network_gateway = "10.10.10.1"
network_bridge  = "vmbr0"
dns_servers     = "10.10.10.1 8.8.8.8"

# SSH public key for VM access (optional)
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EA... your-key-here"

# Default password for cloud-init VMs
vm_default_password = "your-password-here"

# Storage
storage_pool = "local-lvm"
iso_storage  = "local"

# Cloudflare DNS API token
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Needs Zone:DNS:Edit permission for halitdincer.com
cloudflare_api_token = "your-cloudflare-api-token-here"

# Namecheap (registrar — manages nameserver delegation to Cloudflare)
# Get API key at: https://www.namecheap.com/support/api/intro/
namecheap_user_name = "your-namecheap-username"
namecheap_api_user  = "your-namecheap-username"
namecheap_api_key   = "your-namecheap-api-key"

# Grafana Cloud
# - URL: your stack URL (e.g. https://halitdincer.grafana.net)
# - Token: create a Service Account with Admin scope at:
#     <your-stack>.grafana.net/admin/serviceaccounts
#   then generate a token and paste it here.
grafana_url        = "https://your-stack.grafana.net"
grafana_auth_token = "glsa_your_service_account_token_here"

# Cloud Grafana auto-provisions Mimir + Loki datasources. Names usually start
# with "grafanacloud-"; the defaults below match common stacks but you can
# override if yours are renamed (Connections → Data sources to confirm).
# grafana_mimir_datasource_name = "grafanacloud-prom"
# grafana_loki_datasource_name  = "grafanacloud-logs"

# ntfy.sh topic that Grafana Cloud webhook contact point posts to.
# ntfy_topic = "halitdincer-homeserver"
